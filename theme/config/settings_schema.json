    "settings": [
      { "type": "color", "id": "color_primary", "label": "Primary (Coral)", "default": "#C9683E" },
      { "type": "color", "id": "color_secondary", "label": "Secondary (Teal)", "default": "#E0A458" },
      { "type": "color", "id": "color_accent", "label": "Accent (Navy)", "default": "#2B2622" },
      { "type": "color", "id": "color_cream", "label": "Cream", "default": "#F3E9D6" },
      { "type": "color", "id": "color_mint", "label": "Mint", "default": "#F0DCC0" },
      { "type": "color", "id": "color_text", "label": "Text", "default": "#2B2622" },
      { "type": "color", "id": "color_background", "label": "Page background", "default": "#FBF4E7" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "font_picker", "id": "heading_font", "label": "Headings", "default": "fraunces_n7" },
      { "type": "font_picker", "id": "body_font", "label": "Body text", "default": "nunito_n4" }
    ]
  },
  {
