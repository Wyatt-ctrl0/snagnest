    "settings": [
      { "type": "image_picker", "id": "logo", "label": "Logo image" },
      { "type": "image_picker", "id": "favicon", "label": "Favicon" },
      { "type": "text", "id": "logo_text_part1", "label": "Logo text - first word", "default": "Snag" },
      { "type": "text", "id": "logo_text_part2", "label": "Logo text - second word", "default": "Nest" }
    ]
  },
  {
    "name": "Free Shipping",
    "settings": [
      { "type": "number", "id": "free_shipping_threshold", "label": "Free shipping threshold ($)", "default": 50 }
    ]
  },
  {
    "name": "Welcome Promo Popup",
    "settings": [
      { "type": "checkbox", "id": "promo_popup_enabled", "label": "Enable promo popup", "default": true },
      { "type": "text", "id": "promo_popup_title", "label": "Title", "default": "Welcome to the Nest" },
      { "type": "text", "id": "promo_popup_subtitle", "label": "Subtitle", "default": "10% off your first order over $50" },
      { "type": "text", "id": "promo_popup_discount", "label": "Discount display", "default": "10% OFF" },
      { "type": "text", "id": "promo_popup_code", "label": "Promo code", "default": "WELCOME10" }
    ]
  },
  {
    "name": "Bundle Upsell Popup",
    "settings": [
      { "type": "checkbox", "id": "bundle_upsell_enabled", "label": "Enable bundle upsell at checkout", "default": true, "info": "Shows a 'bundle &amp; save' popup when shoppers click Checkout in the cart drawer." },
      { "type": "text", "id": "bundle_upsell_eyebrow", "label": "Eyebrow", "default": "Wait, one more thing" },
      { "type": "text", "id": "bundle_upsell_title", "label": "Title (HTML allowed)", "default": "Bundle up & <em>save</em> before you check out" },
      { "type": "text", "id": "bundle_upsell_subtitle", "label": "Subtitle", "default": "Add these customer favorites to your order at a discount. A great way to try something new." },
      { "type": "textarea", "id": "bundle_upsell_items", "label": "Items", "info": "Comma-separated: emoji|name|price|color (color = mint, coral, peach, cream)", "default": "🧰|Multi-Tool Kit|14.99|coral,🌿|Wellness Roll-On|18.99|peach" },
      { "type": "text", "id": "bundle_upsell_compare", "label": "Compare-at total ($)", "default": "33.98" },
      { "type": "text", "id": "bundle_upsell_price", "label": "Bundle total ($)", "default": "27.18" }
