<section class="section">
  <div class="container">
    <div class="section-head">
      <h1>Search</h1>
      <form action="/search" method="get" role="search" class="newsletter-form" style="max-width:540px;margin:1rem auto;">
        <label for="search-input" class="visually-hidden" style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">Search products</label>
        <input id="search-input" type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products..." aria-label="Search products" required>
        <input type="hidden" name="type" value="product">
        <input type="hidden" name="options[prefix]" value="last">
        <button type="submit" class="btn btn-primary">Search</button>
      </form>
    </div>

    {%- if search.performed -%}
      <p class="text-center" style="color:rgba(31,41,55,0.6);" aria-live="polite">{{ search.results_count }} results for “{{ search.terms }}”</p>
      {%- if search.results.size > 0 -%}
        <div class="products-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div style="text-align:center;padding:3rem;">
          <p>No results. Try another search.</p>
          <a href="/collections/all" class="btn btn-primary">Browse All</a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>
