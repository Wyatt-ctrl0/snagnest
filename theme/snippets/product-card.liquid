{%- comment -%}
  Product card. v18 polish pass:
  - Wishlist heart un-nested from product anchor (was nested interactive,
    invalid HTML + screen-reader breakage).
  - Style block guarded with assign-once so the rules render at most one
    time per template render, not 24x on a paginated collection page.
  - Wishlist heart position matches assets/theme.css (top/right 0.85rem)
    so the un-nesting refactor doesn't shift the icon ~3px tighter.
  v21 (2026-05-28): no-image fallback paw swapped from emoji to inline SVG.
{%- endcomment -%}
{%- unless product_card_wrap_styles_rendered -%}
  {%- assign product_card_wrap_styles_rendered = true -%}
  <style>
    .product-card-wrap { position: relative; display: block; }
    .product-card-wrap .wishlist-heart {
      position: absolute;
      top: 0.85rem;
      right: 0.85rem;
      z-index: 2;
    }
    .product-card .media .product-card-noimg {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      color: var(--color-secondary);
    }
    .product-card .media .product-card-noimg .ms-icon { width: 64px; height: 64px; }
  </style>
{%- endunless -%}
<div class="product-card-wrap" data-testid="product-card-wrap-{{ product.handle }}">
  <button type="button"
          class="wishlist-heart"
          data-wishlist-toggle
          data-product-handle="{{ product.handle }}"
          data-product-title="{{ product.title | escape }}"
          data-product-vendor="{{ product.vendor | escape }}"
          data-product-price="{{ product.price | money }}"
          data-product-price-cents="{{ product.price }}"
          data-product-url="{{ product.url }}"
          data-product-image="{%- if product.featured_image != blank -%}{{ product.featured_image | image_url: width: 600 }}{%- endif -%}"
          data-product-variant-id="{{ product.selected_or_first_available_variant.id }}"
          aria-label="Save {{ product.title | escape }} to wishlist"
          aria-pressed="false"
          data-testid="wishlist-heart-{{ product.handle }}">
    <svg class="wishlist-heart-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
  </button>
  <a href="{{ product.url }}" class="product-card" data-testid="product-card-{{ product.handle }}">
    <div class="media">
      {%- if product.featured_image != blank -%}
        <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy">
      {%- else -%}
        <div class="product-card-noimg" aria-hidden="true">{%- render 'icon-glyph', glyph: 'bag' -%}</div>
      {%- endif -%}
      {%- if product.available == false -%}
        <span class="badge" style="background: rgba(31,41,55,0.72);">Sold Out</span>
      {%- elsif product.compare_at_price > product.price -%}
        <span class="badge">Sale</span>
      {%- elsif product.tags contains 'bestseller' -%}
        <span class="badge">Bestseller</span>
      {%- elsif product.tags contains 'new' -%}
        <span class="badge">New</span>
      {%- endif -%}
    </div>
    <div class="info">
      {%- if product.vendor != blank -%}<div class="vendor">{{ product.vendor }}</div>{%- endif -%}
      <h2 class="title">{{ product.title }}</h2>
      <div class="price">
        {%- if product.compare_at_price > product.price -%}
          <span class="compare">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
        {{ product.price | money }}
      </div>
    </div>
  </a>
</div>
