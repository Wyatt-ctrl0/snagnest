{%- comment -%}
  v21 (2026-05-28): semantic icon key -> inline Lucide-style SVG.
  Replaces emoji-as-icons (cross-platform inconsistent, off-brand) per ui-ux-pro-max
  "no emoji as icons" rule. Usage: {% render 'icon-glyph', glyph: block.settings.icon %}
  Accepts a key (truck, returns, heart, shield, snowflake, bed, bone, bag, paw) or a
  legacy emoji; unknown values render as-is so nothing ever disappears.
{%- endcomment -%}
{%- assign g = glyph | default: '' | strip -%}
{%- capture _svg_open -%}<svg class="ms-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">{%- endcapture -%}
{%- case g -%}
  {%- when 'truck', '🚚' -%}{{ _svg_open }}<path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"/><path d="M14 9h4l4 4v4c0 .6-.4 1-1 1h-2"/><circle cx="7" cy="18" r="2"/><path d="M15 18H9"/><circle cx="17" cy="18" r="2"/></svg>
  {%- when 'returns', 'refund', '↩️', '↩' -%}{{ _svg_open }}<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
  {%- when 'heart', 'donation', '💝', '❤️', '❤' -%}{{ _svg_open }}<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
  {%- when 'shield', 'lock', 'secure', '🔒' -%}{{ _svg_open }}<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
  {%- when 'snowflake', 'cooling', '❄️', '❄' -%}{{ _svg_open }}<line x1="2" x2="22" y1="12" y2="12"/><line x1="12" x2="12" y1="2" y2="22"/><path d="m20 16-4-4 4-4"/><path d="m4 8 4 4-4 4"/><path d="m16 4-4 4-4-4"/><path d="m8 20 4-4 4 4"/></svg>
  {%- when 'bed', 'sleep', '🛏️', '🛏' -%}{{ _svg_open }}<path d="M2 4v16"/><path d="M2 8h18a2 2 0 0 1 2 2v10"/><path d="M2 17h20"/><path d="M6 8v9"/></svg>
  {%- when 'bone', 'play', '🦴' -%}{{ _svg_open }}<path d="M17 10c.7-.7 1.69 0 2.5 0a2.5 2.5 0 1 0 0-5 .5.5 0 0 1-.5-.5 2.5 2.5 0 1 0-5 0c0 .81.7 1.8 0 2.5l-7 7c-.7.7-1.69 0-2.5 0a2.5 2.5 0 0 0 0 5c.28 0 .5.22.5.5a2.5 2.5 0 1 0 5 0c0-.81-.7-1.8 0-2.5Z"/></svg>
  {%- when 'bag', 'shop', '🛍️', '🛍' -%}{{ _svg_open }}<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
  {%- else -%}{{ _svg_open }}<circle cx="11" cy="4" r="2"/><circle cx="18" cy="8" r="2"/><circle cx="20" cy="16" r="2"/><path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/></svg>
{%- endcase -%}
