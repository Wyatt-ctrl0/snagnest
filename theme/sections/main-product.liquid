  html body #judgeme_product_reviews .jdgm-star,
  html body #judgeme_product_reviews .jdgm-star.jdgm--on,
  html body .jdgm-all-reviews-rating .jdgm-star.jdgm--on {
    color: var(--color-primary) !important;
  }
  html body #judgeme_product_reviews .jdgm-star.jdgm--off,
  html body .jdgm-all-reviews-rating .jdgm-star.jdgm--off {
    color: rgba(232, 118, 90, 0.25) !important;
  }

  /* Sort dropdown + filter pills */
  html body #judgeme_product_reviews select,
  html body #judgeme_product_reviews .jdgm-rev-widg__sort-dropdown {
    font-family: var(--font-body) !important;
    border: 1px solid rgba(31, 41, 55, 0.18) !important;
    border-radius: 12px !important;
    padding: 0.6rem 0.85rem !important;
    background: #fff !important;
    color: var(--color-text) !important;
    font-size: 0.92rem !important;
  }

  /* Individual review card */
  html body #judgeme_product_reviews .jdgm-rev {
    background: #fff !important;
    border: 1px solid rgba(31, 41, 55, 0.06) !important;
    border-radius: 16px !important;
    padding: 1.5rem 1.6rem !important;
    margin-bottom: 1rem !important;
    box-shadow: 0 2px 8px rgba(31, 41, 55, 0.04) !important;
  }
  /* Review header (rating + name) */
  html body #judgeme_product_reviews .jdgm-rev__header,
  html body #judgeme_product_reviews .jdgm-rev__rating {
    margin-bottom: 0.4rem !important;
  }
  html body #judgeme_product_reviews .jdgm-rev__author,
  html body #judgeme_product_reviews .jdgm-rev__reviewer-name {
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
    color: var(--color-text) !important;
    font-size: 1rem !important;
  }
  html body #judgeme_product_reviews .jdgm-rev__timestamp,
  html body #judgeme_product_reviews .jdgm-rev__location {
    font-family: var(--font-body) !important;
    color: rgba(31, 41, 55, 0.6) !important;
    font-size: 0.82rem !important;
  }
  /* Verified-buyer badge — small pill */
  html body #judgeme_product_reviews .jdgm-rev__verified-badge,
  html body #judgeme_product_reviews .jdgm-rev__buyer-badge {
    background: rgba(95, 180, 184, 0.14) !important;
    color: var(--color-secondary) !important;
    font-family: var(--font-body) !important;
    font-weight: 700 !important;
    font-size: 0.7rem !important;
    letter-spacing: 0.04em !important;
    padding: 0.2rem 0.6rem !important;
    border-radius: 999px !important;
    text-transform: uppercase !important;
  }
  /* Review title (e.g. "Worked great") */
  html body #judgeme_product_reviews .jdgm-rev__title {
    font-family: var(--font-heading) !important;
    font-weight: 800 !important;
    color: var(--color-text) !important;
    font-size: 1.15rem !important;
    margin: 0.5rem 0 0.4rem !important;
  }
  /* Review body */
  html body #judgeme_product_reviews .jdgm-rev__body,
  html body #judgeme_product_reviews .jdgm-rev__body p {
    font-family: var(--font-body) !important;
    color: rgba(31, 41, 55, 0.85) !important;
    line-height: 1.6 !important;
    font-size: 0.98rem !important;
  }
  /* "Was this helpful?" + Reply links */
  html body #judgeme_product_reviews .jdgm-rev__actions,
  html body #judgeme_product_reviews .jdgm-rev__reply {
    font-family: var(--font-body) !important;
    color: rgba(31, 41, 55, 0.65) !important;
    font-size: 0.85rem !important;
  }
  /* Shop owner reply card — slightly different bg to distinguish */
  html body #judgeme_product_reviews .jdgm-rev__reply,
  html body #judgeme_product_reviews .jdgm-rev__shop-owner-reply {
    background: var(--color-cream) !important;
    border-left: 3px solid var(--color-primary) !important;
    border-radius: 8px !important;
    padding: 0.85rem 1.1rem !important;
    margin-top: 0.85rem !important;
  }
  /* Pagination buttons */
  html body #judgeme_product_reviews .jdgm-paginate {
    margin-top: 1.5rem !important;
    display: flex !important;
    gap: 0.4rem !important;
    justify-content: center !important;
  }
  html body #judgeme_product_reviews .jdgm-paginate .jdgm-paginate__page,
  html body #judgeme_product_reviews .jdgm-paginate__page {
    font-family: var(--font-body) !important;
    font-weight: 600 !important;
    color: var(--color-text) !important;
    background: #fff !important;
    border: 1px solid rgba(31, 41, 55, 0.12) !important;
    border-radius: 999px !important;
    padding: 0.5rem 0.9rem !important;
    min-width: 36px !important;
    min-height: 36px !important;
    text-decoration: none !important;
    transition: background 0.15s, border-color 0.15s !important;
  }
  html body #judgeme_product_reviews .jdgm-paginate__page:hover {
    border-color: var(--color-primary) !important;
    color: var(--color-primary) !important;
  }
  html body #judgeme_product_reviews .jdgm-paginate__page.jdgm-paginate__current-page {
    background: var(--color-primary) !important;
    color: var(--color-text) !important;
    border-color: var(--color-primary) !important;
  }

  /* Histogram bars (5★ 4★ 3★ counts in summary) */
  html body #judgeme_product_reviews .jdgm-histogram__bar-content,
  html body #judgeme_product_reviews .jdgm-histogram__bar {
    background: rgba(232, 118, 90, 0.18) !important;
    border-radius: 4px !important;
  }
  html body #judgeme_product_reviews .jdgm-histogram__bar-content--filled,
  html body #judgeme_product_reviews .jdgm-histogram__bar-content-active {
    background: var(--color-primary) !important;
  }

  /* Mobile: tighten review-card padding */
  @media (max-width: 600px) {
    html body #judgeme_product_reviews .jdgm-rev { padding: 1.2rem 1.1rem !important; border-radius: 12px !important; }
    html body #judgeme_product_reviews .jdgm-rev-widg__summary { padding: 1.3rem !important; border-radius: 14px !important; }
  }

  /* ===== v18 Customer Reviews section header =====
     Two-column header: eyebrow + heading + empty-state-or-summary on the left,
     Write-a-review button on the right. Mobile stacks them. The Judge.me stock
     widgets are kept in the DOM so the JM script can auto-bind them and so
     SEO crawls real review markup once reviews land — but we hide the bare/
     empty Judge.me widgets via CSS so a 0-review page doesn't show ugly empty
     colored boxes. */
  .ms-reviews-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
    border-bottom: 1.5px solid rgba(31,41,55,0.1);
  }
  .ms-reviews-header-text { flex: 1; min-width: 240px; }
  .ms-reviews-header-action {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }
  .ms-reviews-eyebrow {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin: 0 0 0.4rem;
  }
  .ms-reviews-heading {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 2rem;
    line-height: 1.15;
    margin: 0 0 0.65rem;
    color: var(--color-text);
  }
  .ms-reviews-heading em {
    color: var(--color-primary);
    font-style: italic;
  }
  .ms-reviews-meta {
    margin: 0;
    font-size: 0.92rem;
    color: rgba(31,41,55,0.78);
    line-height: 1.5;
    max-width: 520px;
  }
  .ms-reviews-meta-empty { font-style: italic; }
  .ms-reviews-stars {
    color: var(--color-primary);
    font-size: 1.1rem;
    letter-spacing: 1px;
    margin-right: 0.5rem;
    vertical-align: -1px;
  }
  .ms-reviews-meta-text {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
  }
  .ms-write-review-btn {
    padding: 0.85rem 1.6rem;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  /* Hide Judge.me's stock write-rev-link box inside our section-header
     container. JM styles its empty container as a solid teal block — ugly
     when there's no content inside. We use our own .ms-write-review-btn.
     LOCK: must use display:none (not visibility/opacity) so the container
     stays out of focus order. Scoped to the header container only —
     a :empty fallback was removed because JM injects a child <a> tag
     into the container during loader.js hydration, which makes :empty
     stop matching even before reviews exist. */
  .ms-reviews-header-action .jdgm-write-rev-link { display: none !important; }

  /* Hide the empty-state meta line once Judge.me hydrates with real content
     (handled by JS adding [data-ms-reviews-hydrated] to the header). */
  .ms-reviews-header[data-ms-reviews-hydrated="true"] .ms-reviews-meta-empty { display: none; }

  /* Hide the all-reviews-rating widget while empty. Once JM populates it (5
     stars + count), the empty:has() trick releases and lets it render. The
     widget then renders BELOW the section header (separate row). */
  .ms-jdgm-rating { display: none; }
  .ms-jdgm-rating.jdgm--done-setup:has(.jdgm-rev-widg-summary),
  .ms-jdgm-rating.jdgm--done-setup .jdgm-prev-badge[data-average-rating]:not([data-average-rating="0.00"]) {
    display: block;
    margin-bottom: 1.5rem;
  }

  /* Mobile: stack header items vertically, button full-width. */
  @media (max-width: 767px) {
    .ms-reviews-header { flex-direction: column; align-items: stretch; }
    .ms-reviews-header-action { align-items: stretch; }
    .ms-write-review-btn { width: 100%; }
    .ms-reviews-heading { font-size: 1.6rem; }
  }

  /* v18 mobile-port pass: WCAG/HIG-compliant 44px minimum tap targets on
     PDP variant + qty controls. Default theme.css ships them sub-44px
     (option-value ~32px tall, qty button 40px wide). These override at
     all viewport widths so desktop also benefits. */
  .product-quantity .qty-control button { min-width: 44px; min-height: 44px; }
  .option-values .option-value { min-height: 44px; padding: 0.75rem 1.2rem; }
  /* Hero badge: prevent horizontal page-scroll on small viewports. The
     default .hero-badge sits at left:-20px which pushes 20px past the
     container edge — fine at desktop, causes whole-page horizontal
     scroll on 375px. Pin it inside the container on mobile. */
  @media (max-width: 600px) {
    .hero-badge { left: 0 !important; width: 110px !important; bottom: -16px !important; }
    .hero { overflow-x: clip; }
  }

  /* Bundle "What's inside" — force uniform thumbnail size + alignment.
     Without these overrides, image cells render at ~142px but paw-fallback
     cells shrink to ~93px, so a row of mixed items looks ragged. We pin
     the thumb to a square with aspect-ratio, center contents, and have
     the fallback fill the cell. The grid itself uses equal columns so
     captions line up under the thumbs. */
  .product-bundle-contents-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
    gap: 1rem;
    align-items: start;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .product-bundle-contents-grid > li { display: flex; }
  .product-bundle-contents-thumb {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(31, 41, 55, 0.04);
  }
  .product-bundle-contents-fallback-style {} /* sentinel for v19 patch below */
  .product-bundle-contents-fallback {
    font-family: var(--font-heading) !important;
    font-weight: 800 !important;
    color: var(--color-secondary) !important;
    background: linear-gradient(135deg, rgba(95,180,184,0.10), rgba(232,118,90,0.08)) !important;
    letter-spacing: 0.02em;
    border-radius: inherit;
  }
  .product-bundle-contents-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .product-bundle-contents-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-size: 2rem;
    opacity: 0.45;
  }
  .product-bundle-contents-title {
    display: block;
    text-align: center;
    font-size: 0.92rem;
    line-height: 1.3;
    margin-top: 0.4rem;
  }
  .product-bundle-contents-link {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    text-decoration: none;
    color: inherit;
    width: 100%;
    border-radius: 12px;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .product-bundle-contents-link:hover { transform: translateY(-2px); }
  .product-bundle-contents-link:hover .product-bundle-contents-title { color: var(--color-primary); text-decoration: underline; text-underline-offset: 2px; }
  .product-bundle-contents-link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }
  /* Self-link guard: when the bundle contains the product the user is
     already viewing, render as a non-interactive span instead of an anchor.
     Visually de-emphasize so the user understands it's the current page. */
  .product-bundle-contents-link.is-current {
    cursor: default;
    opacity: 0.7;
  }
  .product-bundle-contents-link.is-current:hover { transform: none; }
  .product-bundle-contents-link.is-current .product-bundle-contents-title { color: inherit; text-decoration: none; }
</style>

<script>
  // Lightbox / thumbnail sync: when the user clicks a thumbnail, the main
  // image src swaps via theme.js's initProductGallery, but the lightbox
  // attribute on the wrapper stayed pinned to the FEATURED image — so
  // clicking the enlarged view always opened image #1. Mirror the swap
  // onto the wrapper here so the lightbox opens the currently-shown image.
  (function () {
    var thumbs = document.querySelectorAll('[data-product-thumb]');
    var main = document.querySelector('[data-product-main-img]');
    var wrapper = main && main.closest('[data-lightbox]');
    if (!thumbs.length || !main || !wrapper) return;
    thumbs.forEach(function (t) {
      t.addEventListener('click', function () {
        var hires = t.getAttribute('data-img-large') || t.getAttribute('data-img');
        if (hires) wrapper.setAttribute('data-lightbox', hires);
      });
    });
  })();

  (function () {
    // Hydration race guard: server-side metafield branch decides the empty
    // state, but Judge.me hydrates client-side. If metafields lag the actual
    // review data (common right after the first review lands), the page would
    // claim "No reviews yet" next to a populated star widget below. When JM
    // signals it's done rendering AND the rating widget reports a non-zero
    // average, flip the header into hydrated mode so the empty line hides.
    var header = document.querySelector('.ms-reviews-header');
    if (!header) return;
    function checkHydrated() {
      // Primary signal: jdgm-prev-badge data-average-rating / data-number-of-reviews
      var badge = document.querySelector('.jdgm-prev-badge[data-average-rating], .jdgm-all-reviews-rating .jdgm-prev-badge[data-average-rating]');
      var avg = badge && parseFloat(badge.getAttribute('data-average-rating'));
      var ct = badge && parseInt(badge.getAttribute('data-number-of-reviews'), 10);
      if ((avg && avg > 0) || (ct && ct > 0)) {
        header.setAttribute('data-ms-reviews-hydrated', 'true');
        return true;
      }
      // Fallback: any rendered review item or summary widget content with non-zero rating
      var hasReviewRow = document.querySelector('#judgeme_product_reviews .jdgm-rev, .jdgm-rev-widg__reviews .jdgm-rev');
      var summary = document.querySelector('.jdgm-rev-widg-summary, .jdgm-rev-widg__summary');
      if (hasReviewRow || (summary && summary.textContent && /[1-9]/.test(summary.textContent))) {
        header.setAttribute('data-ms-reviews-hydrated', 'true');
        return true;
      }
      return false;
    }
    // Try once on DOM ready, then poll a few times in case JM is slow.
    if (!checkHydrated()) {
      var tries = 0;
      var iv = setInterval(function () {
        tries++;
        if (checkHydrated() || tries > 20) clearInterval(iv);
      }, 500);
    }
    document.addEventListener('jdgm.ready', checkHydrated);
  })();

  (function () {
    // v18 "Write a review" button → opens Judge.me's submit-review modal.
    //
    // How it works in 2 steps:
    //  1. .click() on the matching .jdgm-write-rev-link[data-id="<pid>"]
    //     triggers JM's loader.js delegated listener, which builds the
    //     modal DOM and appends it to <body> (display:none initially).
    //  2. JM's own listener also sets display:block — BUT only on trusted
    //     user clicks (event.isTrusted === true). A synthetic .click() from
    //     JS hits the build path but skips the show path. So we MutationObserve
    //     <body> for the modal's appearance and flip display:block ourselves.
    //
    // _WriteReviewModal.setup() invoked directly throws because the
    // jQuery .urlParam extension isn't loaded by this shop's JM bundle —
    // we route around that by reusing JM's binding.
    var btnSelector = '[data-ms-write-review]';
    var clickPending = false;  // anti-rapid-fire guard for cold-load window
    var clickHandler = function (e) {
      var btn = e.target && e.target.closest && e.target.closest(btnSelector);
      if (!btn) return;
      e.preventDefault();
      // Drop subsequent clicks while a previous click is still resolving
      // (either polling for JM to load or waiting for modal to appear).
      // Without this, rapid double-tap can stack 2+ setInterval polls and
      // fire jmLink.click() multiple times once JM hydrates.
      if (clickPending) return;
      clickPending = true;
      var pid = btn.getAttribute('data-product-id');
      // Only scroll if we're NOT already inside the reviews section — avoids
      // yanking the user away after they've already navigated there.
      var section = document.getElementById('ms-reviews-section');
      if (section && !section.contains(btn)) {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      // Double-click idempotency: if a modal already exists AND is VISIBLE,
      // don't construct a second one — JM's setup() appends to <body>
      // every call. Rapid double-clicks would otherwise stack modals.
      //
      // CRITICAL: must check visibility, not just existence. JM's loader.js
      // pre-builds the modal template at page load in display:none state.
      // An earlier version bailed on any modal in DOM — silently failing
      // every user click because the prebuilt-hidden modal always exists.
      var existingModal = document.querySelector('.jdgm-write-review-modal');
      if (existingModal && getComputedStyle(existingModal).display !== 'none') return;
      // Try the official JM path first: build a real _WriteReviewModal
      // and call setup(). This populates the form content (rating stars,
      // name/email fields, etc.) — the path that just .click()'ing the
      // widget skips. JM's setup() needs a jQuery .urlParam extension
      // which this shop's bundle doesn't ship, so we polyfill it once.
      var openedViaSetup = false;
      try {
        if (window.jdgm && window.jdgm.$ && window.jdgm.$.fn) {
          if (typeof window.jdgm.$.fn.urlParam !== 'function') {
            // Escape regex meta in the param name in case a future JM
            // bundle ever passes user-influenced input. Today JM only
            // calls this with literal strings, but it's cheap defense.
            window.jdgm.$.fn.urlParam = function (name) {
              var safe = String(name).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
              var match = new RegExp('[?&]' + safe + '=([^&#]*)').exec(window.location.href);
              return match ? decodeURIComponent(match[1].replace(/\+/g, ' ')) : null;
            };
            // Surface the polyfill in DevTools so a future maintainer
            // notices we're filling a gap in JM's bundle. If a real JM
            // urlParam ships later with a different signature, this
            // log is the breadcrumb that explains why something broke.
            if (window.console && console.info) {
              console.info('[ms] polyfilled jdgm.$.fn.urlParam (missing from this shop\'s JM bundle)');
            }
          }
          var $jmLink = window.jdgm.$('.jdgm-write-rev-link[data-id="' + pid + '"]').first();
          if ($jmLink.length && typeof window.jdgm._WriteReviewModal === 'function') {
            var modal = new window.jdgm._WriteReviewModal($jmLink);
            modal.setup();
            // CRITICAL: setup() builds the modal DOM but JM's natural show
            // path (which adds display:block) only fires for trusted user
            // clicks on .jdgm-write-rev-link itself. When we call setup()
            // directly, we must force the modal visible ourselves. Use an
            // interval (not single setTimeout) because JM may keep
            // re-applying display:none for a few frames during its own
            // setup teardown. Cap at 2 seconds.
            var showShots = 0;
            var showSetupModal = setInterval(function () {
              showShots++;
              var modalEl = document.querySelector('.jdgm-write-review-modal');
              if (modalEl) {
                modalEl.style.setProperty('display', 'block', 'important');
                if (getComputedStyle(modalEl).display === 'block' && showShots > 4) {
                  clearInterval(showSetupModal);
                  clickPending = false;
                }
              }
              if (showShots >= 40) { clearInterval(showSetupModal); clickPending = false; }
            }, 50);
            openedViaSetup = true;
          }
        }
      } catch (err) { /* fall through to .click() path below */ }
      if (openedViaSetup) {
        // Modal built via JM's official path + force-show interval running.
        // clickPending gets cleared inside the showSetupModal interval.
        return;
      }
      // Fallback: find the JM write-rev-link scoped to THIS product's id
      // and .click() it. JM's loader.js binds a delegated listener that
      // builds the modal — but on programmatic (non-trusted) clicks the
      // show step doesn't fire, so we force display:block until JM stops
      // resetting it. Caps at 1.5s.
      //
      // Cold-load retry: if Judge.me's loader.js hasn't hydrated yet,
      // window.jdgm may exist but .jdgm-write-rev-link[data-id] may not
      // be queryable as expected (or JM hasn't bound its delegated
      // listener yet). Poll up to 4s for the widget to appear AND for
      // JM's binding to be active, then click. This addresses the
      // "click does nothing" case when a user lands on the page and
      // hits the button before JM finishes loading.
      var coldAttempts = 0;
      var pollLink = setInterval(function () {
        coldAttempts++;
        var jmLink = document.querySelector('.jdgm-write-rev-link[data-id="' + pid + '"]');
        var jmReady = window.jdgm && typeof window.jdgm._WriteReviewModal === 'function';
        if (jmLink && jmReady) {
          clearInterval(pollLink);
          try { jmLink.click(); } catch (_) {}
          // Then force display:block until JM stops resetting (1.5s cap).
          var showAttempts = 0;
          var showInterval = setInterval(function () {
            showAttempts++;
            var modalEl = document.querySelector('.jdgm-write-review-modal');
            if (modalEl) {
              modalEl.style.setProperty('display', 'block', 'important');
              if (getComputedStyle(modalEl).display === 'block' && showAttempts > 3) {
                clearInterval(showInterval);
                clickPending = false;
              }
            }
            if (showAttempts >= 30) { clearInterval(showInterval); clickPending = false; }
          }, 50);
        }
        if (coldAttempts >= 40) {
          clearInterval(pollLink);
          // Last-resort: visible feedback to the user that something's
          // wrong rather than a silent no-op. Toast briefly + scroll to
          // the JM widget area so they at least see review content.
          var toast = document.querySelector('[data-app-toast]');
          if (toast) {
            toast.textContent = 'Reviews are still loading. Try again in a moment.';
            toast.classList.add('is-visible');
            setTimeout(function () { toast.classList.remove('is-visible'); }, 3500);
          }
          clickPending = false;
        }
      }, 100);
      // Belt-and-suspenders: also clear pending after 5s to recover from
      // any path that fails to clear it explicitly.
      setTimeout(function () { clickPending = false; }, 5000);
    };
    document.addEventListener('click', clickHandler);
    // Theme-editor / section reload teardown so we don't stack listeners.
    document.addEventListener('shopify:section:unload', function handler(ev) {
      var sec = document.getElementById('ms-reviews-section');
      if (sec && ev.target && ev.target.contains(sec)) {
        document.removeEventListener('click', clickHandler);
        document.removeEventListener('shopify:section:unload', handler);
      }
    });
  })();

  (function () {
    var bar = document.querySelector('[data-product-sticky-atc]');
    var primary = document.querySelector('[data-product-atc-primary]');
    if (!bar || !primary || !('IntersectionObserver' in window)) return;
    var io = new IntersectionObserver(function (entries) {
      var btn = bar.querySelector('[data-product-sticky-atc-btn]');
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          bar.classList.remove('is-visible');
          bar.setAttribute('aria-hidden', 'true');
          bar.setAttribute('inert', '');
          if (btn) btn.setAttribute('tabindex', '-1');
        } else {
          bar.classList.add('is-visible');
          bar.setAttribute('aria-hidden', 'false');
          bar.removeAttribute('inert');
          if (btn) btn.removeAttribute('tabindex');
        }
      });
    }, { rootMargin: '0px 0px -40px 0px', threshold: 0 });
    io.observe(primary);
    // Tear down on Shopify theme-editor section reload so we don't leak observers.
    document.addEventListener('shopify:section:unload', function handler(ev) {
      if (ev.target && ev.target.contains(bar)) {
        io.disconnect();
        document.removeEventListener('shopify:section:unload', handler);
      }
    });
  })();
</script>

<section class="section" id="ms-reviews-section" aria-labelledby="ms-reviews-heading">
  <div class="container">
    {%- comment -%}
      Judge.me integration. The app's loader.js auto-binds the jdgm-* widgets
      below by data-id. Empty Judge.me widgets render as ugly colored boxes —
      we CSS-hide them while empty so the pre-launch empty state looks clean,
      and use our own copy + button for the empty state. Once reviews land,
      Judge.me populates the widgets and we let them render.
    {%- endcomment -%}
    {%- assign has_legacy = false -%}
    {%- if product.metafields.judgeme.widget != blank -%}
      {%- assign has_legacy = true -%}
    {%- endif -%}

    {%- assign jdgm_rating_section = product.metafields.judgeme.rating | default: 0 | times: 1 -%}
    {%- assign jdgm_count_section = product.metafields.judgeme.review_count | default: 0 | plus: 0 -%}
    {%- comment -%} Star rendering: filled vs empty stars from the real rating. {%- endcomment -%}
    {%- assign jdgm_section_full = jdgm_rating_section | round -%}
    {%- if jdgm_section_full > 5 -%}{%- assign jdgm_section_full = 5 -%}{%- endif -%}
    {%- if jdgm_section_full < 0 -%}{%- assign jdgm_section_full = 0 -%}{%- endif -%}
    {%- assign jdgm_section_empty = 5 | minus: jdgm_section_full -%}
    {%- capture jdgm_section_stars -%}{% for i in (1..jdgm_section_full) %}★{% endfor %}{% for i in (1..jdgm_section_empty) %}☆{% endfor %}{%- endcapture -%}

    <div class="ms-reviews-header">
      <div class="ms-reviews-header-text">
        <p class="ms-reviews-eyebrow">From our customers</p>
        <h2 class="ms-reviews-heading" id="ms-reviews-heading">Customer <em>reviews</em></h2>
        {%- comment -%} OR not AND: handles edge where JM has count synced but rating still 0 (or vice-versa) during initial review processing. {%- endcomment -%}
        {%- if jdgm_count_section > 0 or jdgm_rating_section > 0 -%}
          <p class="ms-reviews-meta">
            <span class="ms-reviews-stars" aria-label="{{ jdgm_rating_section }} out of 5 stars">{{ jdgm_section_stars }}</span>
            <span class="ms-reviews-meta-text">{{ jdgm_rating_section }} · {{ jdgm_count_section }} verified {% if jdgm_count_section == 1 %}review{% else %}reviews{% endif %}</span>
          </p>
        {%- else -%}
          <p class="ms-reviews-meta ms-reviews-meta-empty" data-ms-empty-state>No reviews yet. If you've tried this product, your honest take helps the next shopper decide.</p>
        {%- endif -%}
      </div>
      <div class="ms-reviews-header-action">
        {%- comment -%} Judge.me's own write-rev-link widget — kept in DOM for SEO + auto-bind, hidden via CSS while empty so the bare teal block doesn't render. {%- endcomment -%}
        <div class="jdgm-widget jdgm-write-rev-link" data-id="{{ product.id }}"></div>
        <button type="button" class="btn btn-primary ms-write-review-btn" aria-label="Write a review for {{ product.title | escape }}" data-ms-write-review data-product-id="{{ product.id }}">Write a review</button>
      </div>
    </div>

    {%- comment -%} jdgm-all-reviews-rating — invisible until JM populates real content. {%- endcomment -%}
    <div class="jdgm-widget jdgm-all-reviews-rating ms-jdgm-rating" data-id="{{ product.id }}"></div>

    <div style='clear:both'></div>
    <div id='judgeme_product_reviews' class='jdgm-widget jdgm-review-widget {% if has_legacy %}jdgm--done-rendering{% endif %}' data-id='{{ product.id }}'>
      {% if has_legacy %}
        {{ product.metafields.judgeme.widget }}
      {% endif %}
    </div>
  </div>
</section>

{%- comment -%} Count available cross-sells once so we can suppress the whole section if there are none — no orphan "You'll also love" header. {%- endcomment -%}
{%- assign available_total = 0 -%}
{%- for prod in collections.all.products -%}
  {%- if prod.id != product.id and prod.available -%}
    {%- assign available_total = available_total | plus: 1 -%}
  {%- endif -%}
{%- endfor -%}
{%- if available_total > 0 -%}
<section class="section">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">You'll also love</span>
      <h2>More <em>trending finds</em></h2>
    </div>
    <div class="products-grid">
      {%- comment -%}
        v18 (2026-05-26): rotate the "You'll also love" starting index by
        product.id so different PDPs surface different cross-sells instead of
        the same 4 products everywhere. Two-pass: skip the first <offset> items
        that pass the filter, then render the next 4.
      {%- endcomment -%}
      {%- assign related_offset = 0 -%}
      {%- if available_total > 4 -%}
        {%- assign related_offset = product.id | modulo: available_total -%}
      {%- endif -%}
      {%- assign skipped = 0 -%}
      {%- assign related_count = 0 -%}
      {%- for prod in collections.all.products -%}
        {%- if prod.id != product.id and prod.available -%}
          {%- if skipped < related_offset -%}
            {%- assign skipped = skipped | plus: 1 -%}
          {%- elsif related_count < 4 -%}
            {% render 'product-card', product: prod %}
            {%- assign related_count = related_count | plus: 1 -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
      {%- comment -%}
        Wrap-around: only fires when the offset pushed us past the end of the
        list AND there are MORE than 4 available products total. If
        available_total <= 4 the first pass already rendered everything (with
        offset=0), so a second pass would just duplicate the first.
      {%- endcomment -%}
      {%- if related_count < 4 and available_total > 4 -%}
        {%- assign wrap_seen = 0 -%}
        {%- for prod in collections.all.products -%}
          {%- if prod.id != product.id and prod.available and related_count < 4 -%}
            {%- if wrap_seen < related_offset -%}
              {%- comment -%} Only render items BEFORE the original offset (which weren't rendered in pass 1). {%- endcomment -%}
              {% render 'product-card', product: prod %}
              {%- assign related_count = related_count | plus: 1 -%}
              {%- assign wrap_seen = wrap_seen | plus: 1 -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

{%- comment -%}
  v18 (2026-05-26): Judge.me review widget at the bottom is visible so customers
  can write reviews. The preview badge near the buy-box is hidden via CSS in the
  inline style block above (#judgeme_product_reviews_preview) — see comment
  there. Both flip back on naturally once you have ~5 real reviews.
{%- endcomment -%}

{% schema %}
{
  "name": "Product",
  "settings": []
}
{% endschema %}
