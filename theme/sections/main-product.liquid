  }
  /* Back / secondary text link */
  html body .jdgm-write-review-modal .jdgm-write-review-modal__nav-btn-back,
  html body .jdgm-write-review-modal .jdgm-write-review-modal__skip-btn {
    color: rgba(31, 41, 55, 0.78) !important;
    font-family: var(--font-body) !important;
    font-size: 0.92rem !important;
    background: transparent !important;
    border: none !important;
    cursor: pointer !important;
    min-height: 44px !important;
    padding: 0.6rem 0.85rem !important;
  }
  html body .jdgm-write-review-modal .jdgm-write-review-modal__nav-btn-back:hover,
  html body .jdgm-write-review-modal .jdgm-write-review-modal__skip-btn:hover {
    color: var(--color-primary) !important;
  }
  /* "Poor / Great" star-rating labels */
  html body .jdgm-write-review-modal .jdgm-write-review-modal__stars-label {
    font-family: var(--font-body) !important;
    color: rgba(31, 41, 55, 0.78) !important;
    font-size: 0.85rem !important;
  }
  /* Mobile: tighten padding */
  @media (max-width: 600px) {
    html body .jdgm-write-review-modal .jdgm-write-review-modal__container {
      border-radius: 16px !important;
    }
    html body .jdgm-write-review-modal .jdgm-write-review-modal__title {
      font-size: 1.4rem !important;
    }
  }

  /* ===== JM REVIEW WIDGET brand polish (v18.3 2026-05-27) =====
     Restyle the entire .jdgm-rev-widg (the list of reviews + summary at
     the bottom of the PDP) to match the SnagNest aesthetic so it
     reads as part of the site, not an embedded JM widget. Active once
     real reviews land — pre-launch the widget is empty + hidden. */

  /* Widget container — light card on cream */
  html body #judgeme_product_reviews .jdgm-rev-widg,
  html body #judgeme_product_reviews .jdgm-rev-widg__reviews {
    font-family: var(--font-body) !important;
    color: var(--color-text) !important;
    background: transparent !important;
    border: none !important;
  }

  /* Widget summary — top section with overall rating */
  html body #judgeme_product_reviews .jdgm-rev-widg__summary {
    background: #fff !important;
    border: 1px solid rgba(31, 41, 55, 0.06) !important;
    border-radius: 18px !important;
    padding: 1.8rem !important;
    box-shadow: 0 4px 14px rgba(31, 41, 55, 0.05) !important;
    margin-bottom: 1.5rem !important;
  }
  html body #judgeme_product_reviews .jdgm-rev-widg__title,
  html body #judgeme_product_reviews .jdgm-rev-widg__summary-text {
