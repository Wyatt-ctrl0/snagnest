<div class="collection-header" data-testid="collection-header">
  <div class="container">
    <span class="eyebrow" style="display:inline-block;font-family:var(--font-heading);font-size:0.85rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:var(--color-secondary);margin-bottom:1rem;">Collection</span>
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p>{{ collection.description }}</p>
    {%- endif -%}
  </div>
</div>

<section class="section">
  <div class="container">
    <div class="collection-toolbar">
      <div class="product-count" data-testid="product-count">{{ collection.products_count | default: collection.all_products_count }} products</div>
    </div>

    {%- if collection.products.size > 0 -%}
      {%- paginate collection.products by 24 -%}
        <div class="products-grid">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product %}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          {%- comment -%} Current-page detection: paginate.parts.title is a STRING and paginate.current_page is an INTEGER, so we coerce both to strings before comparing. Without this, the current page falls through and renders as a pawprint. {%- endcomment -%}
          {%- assign current_page_str = paginate.current_page | append: '' -%}
          <nav class="ms-pagination" aria-label="Collection pagination" data-testid="collection-pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="ms-pagination-arrow" aria-label="Previous page" rel="prev" data-testid="pagination-prev">
                <svg class="ms-pagination-chev" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M15 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            {%- else -%}
              <span class="ms-pagination-arrow is-disabled" aria-hidden="true">
                <svg class="ms-pagination-chev" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M15 6l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="ms-pagination-num" data-testid="pagination-page-{{ part.title }}">{{ part.title }}</a>
              {%- else -%}
                {%- assign part_title_str = part.title | append: '' -%}
                {%- if part_title_str == current_page_str -%}
                  <span class="ms-pagination-num is-current" aria-current="page" data-testid="pagination-current">{{ part.title }}</span>
                {%- else -%}
                  <span class="ms-pagination-num is-paw" data-testid="pagination-gap">
                    <span class="ms-pagination-sr">More pages</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <ellipse cx="6" cy="10" rx="2" ry="2.4" fill="currentColor"/>
                      <ellipse cx="10.3" cy="6.4" rx="2" ry="2.4" fill="currentColor"/>
                      <ellipse cx="14.7" cy="6.4" rx="2" ry="2.4" fill="currentColor"/>
                      <ellipse cx="19" cy="10" rx="2" ry="2.4" fill="currentColor"/>
                      <path d="M12.5 11.5c-3 0-5.5 2.3-5.5 4.8 0 1.5 1.2 2.7 2.8 2.7.9 0 1.7-.3 2.5-.7.5-.2 1-.2 1.4 0 .8.4 1.6.7 2.5.7 1.6 0 2.8-1.2 2.8-2.7 0-2.5-2.5-4.8-5.5-4.8z" fill="currentColor"/>
                    </svg>
                  </span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}

            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="ms-pagination-arrow" aria-label="Next page" rel="next" data-testid="pagination-next">
                <svg class="ms-pagination-chev" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            {%- else -%}
              <span class="ms-pagination-arrow is-disabled" aria-hidden="true">
                <svg class="ms-pagination-chev" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M9 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <div class="collection-empty" data-testid="collection-empty">
        <h3>Nothing on this shelf yet.</h3>
        <p>We haven't added anything here yet. Try <a href="/collections/all">everything we've got</a>.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.ms-pagination {
  display: flex; align-items: center; justify-content: center;
  gap: 0.5rem;
  margin: 3rem 0 1rem;
  flex-wrap: wrap;
}
.ms-pagination-arrow,
.ms-pagination-num {
  min-width: 44px; height: 44px; padding: 0 0.7rem;
  display: inline-flex; align-items: center; justify-content: center;
  border-radius: 12px;
  font-family: var(--font-heading); font-weight: 700; font-size: 0.95rem;
  color: var(--color-text);
  text-decoration: none;
  transition: background 0.18s ease, transform 0.18s ease, color 0.18s ease;
}
.ms-pagination-arrow { box-sizing: border-box; }
.ms-pagination-arrow:hover,
.ms-pagination-num:hover { background: var(--color-cream); }
.ms-pagination-arrow:focus-visible,
.ms-pagination-num:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
.ms-pagination-arrow.is-disabled,
.ms-pagination-num.is-paw {
  pointer-events: none;
}
.ms-pagination-arrow.is-disabled {
  color: rgba(31, 41, 55, 0.45);
  cursor: not-allowed;
}
.ms-pagination-chev { width: 20px; height: 20px; transition: transform 0.18s ease; }
.ms-pagination-arrow[rel="prev"]:hover .ms-pagination-chev { transform: translateX(-2px); }
.ms-pagination-arrow[rel="next"]:hover .ms-pagination-chev { transform: translateX(2px); }
.ms-pagination-num.is-current {
  background: var(--color-mint);
  color: var(--color-text);
}
.ms-pagination-num.is-paw svg {
  width: 22px; height: 22px;
  color: var(--color-secondary);
  opacity: 0.7;
}
.ms-pagination-sr {
  position: absolute;
  width: 1px; height: 1px;
  padding: 0; margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}
.collection-empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: 4rem 1.5rem;
  background: var(--color-cream);
  border-radius: 24px;
  margin-top: 1.5rem;
}
.collection-empty h3 {
  font-family: var(--font-heading);
  font-weight: 800;
  margin-bottom: 0.6rem;
}
.collection-empty p {
  color: rgba(31,41,55,0.7);
  max-width: 440px;
  margin: 0 auto;
}
.collection-empty a {
  color: var(--color-primary);
  font-weight: 700;
  text-decoration: underline;
}
@media (max-width: 480px) {
  .ms-pagination { gap: 0.4rem; }
  .ms-pagination-arrow,
  .ms-pagination-num { min-width: 40px; height: 40px; padding: 0 0.5rem; font-size: 0.9rem; }
  .ms-pagination-num.is-paw svg { width: 19px; height: 19px; }
  .ms-pagination-chev { width: 18px; height: 18px; }
}
{% endstylesheet %}

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
