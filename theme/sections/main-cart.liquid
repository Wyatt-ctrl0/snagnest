<section class="section cart-page" data-testid="cart-page">
  <div class="container" style="max-width: 900px;">
    <div class="section-head" style="text-align:left;">
      <h1>Your Cart</h1>
    </div>

    {%- if cart.item_count > 0 -%}
      {%- assign threshold = settings.free_shipping_threshold | default: 50 -%}
      {%- if threshold == 0 or threshold == blank -%}{%- assign threshold = 50 -%}{%- endif -%}
      {%- assign threshold_cents = threshold | times: 100 -%}
      {%- assign remaining_cents = threshold_cents | minus: cart.total_price -%}
      <div class="cart-page-shipping-bar" data-shipping-bar>
        <div class="shipping-bar-text" data-shipping-text>
          {%- if cart.total_price >= threshold_cents -%}
            &#127881; You&rsquo;ve unlocked <strong>FREE SHIPPING!</strong>
          {%- else -%}
            Spend <strong>${{ remaining_cents | divided_by: 100.0 }}</strong> more for FREE shipping
          {%- endif -%}
        </div>
        <div class="shipping-progress">
          {%- assign pct = cart.total_price | times: 100 | divided_by: threshold_cents -%}
          {%- if pct > 100 -%}{%- assign pct = 100 -%}{%- endif -%}
          <div class="shipping-progress-fill{% if cart.total_price >= threshold_cents %} is-complete{% endif %}" style="width: {{ pct }}%;"></div>
        </div>
      </div>

      {%- form 'cart', cart -%}
        <div style="background:#fff;border-radius:24px;padding:1.5rem;">
          {%- for item in cart.items -%}
            <div class="cart-item" data-testid="cart-line-{{ forloop.index }}">
              <div class="cart-item-image">
                {%- if item.image != blank -%}
                  <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}">
                {%- else -%}
                  <div aria-hidden="true" style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;font-size:2.5rem;background:var(--color-cream,#faf3e7);border-radius:12px;">🛍</div>
                {%- endif -%}
              </div>
              <div>
                <h2 class="cart-item-title">{{ item.product.title }}</h2>{%- comment -%} v20 A9: was h4 jumping from page h1. Item titles are direct children of the cart page so h2 is the correct level. {%- endcomment -%}
                {%- unless item.product.has_only_default_variant -%}
                  <div class="cart-item-variant">{{ item.variant.title }}</div>
                {%- endunless -%}
                <div class="cart-item-controls">
                  <a class="cart-qty-btn" href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}" aria-label="Decrease quantity">&minus;</a>
                  <span class="qty">{{ item.quantity }}</span>
                  <a class="cart-qty-btn" href="/cart/change?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}" aria-label="Increase quantity">+</a>
                </div>
                <a class="cart-item-remove-link" href="{{ item.url_to_remove }}" data-testid="cart-line-{{ forloop.index }}-remove">Remove</a>
              </div>
              <div>
                <div class="cart-item-price">{{ item.final_line_price | money }}</div>
              </div>
            </div>
          {%- endfor -%}

          {%- comment -%} v19 (2026-05-26): removed the disabled promo input — dead UI, looked fillable but wasn't. Helper text below conveys the same information honestly. {%- endcomment -%}
          <p class="cart-page-promo" style="margin: 1rem 0; color: rgba(31,41,55,0.6); font-size: 0.9rem;">Have a promo code? Apply it at checkout.</p>

          <div class="cart-totals" style="margin-top:1.5rem;padding-top:1rem;border-top:2px solid var(--color-cream);">
            <div class="subtotal-label">Subtotal</div>
            <div class="subtotal-value">{{ cart.total_price | money }}</div>
          </div>
          <p style="text-align:right;font-size:0.85rem;color:rgba(31,41,55,0.6);margin:0.25rem 0 1rem;">Taxes &amp; shipping calculated at checkout</p>

          <button type="submit" name="checkout" class="btn btn-primary btn-block" data-testid="cart-checkout-btn">Checkout &rarr;</button>
        </div>
      {%- endform -%}
    {%- else -%}
      <div style="text-align:center;padding:4rem 1rem;">
        <div style="font-size:5rem;margin-bottom:1rem;">🛍</div>
        <h2>Your cart is empty</h2>
        <p>Find something you'll love. Browse our trending finds and add a few favorites.</p>
        <a href="/collections/all" class="btn btn-primary mt-2">Start Shopping</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  /* v18 mobile-port pass: cart-page qty buttons + Remove link were
     rendering as default-styled inline links (~16x20 tap area, no
     border, no padding). theme.css only styled <button> children of
     .cart-item-controls, missing the <a> markup. WCAG/HIG requires
     44x44 minimum tap targets. */
  .cart-item-controls { display: inline-flex; align-items: center; gap: 0.25rem; border: 1px solid rgba(31,41,55,.18); border-radius: 999px; padding: 0.25rem; background: #fff; margin-top: 0.5rem; }
  .cart-item-controls .cart-qty-btn { display: inline-flex; align-items: center; justify-content: center; min-width: 36px; min-height: 36px; width: 36px; height: 36px; border-radius: 50%; text-decoration: none; color: var(--color-text); font-weight: 700; font-size: 1.1rem; line-height: 1; transition: background 0.15s ease; }
  .cart-item-controls .cart-qty-btn:hover, .cart-item-controls .cart-qty-btn:focus-visible { background: var(--color-cream); outline: none; }
  .cart-item-controls .cart-qty-btn:focus-visible { box-shadow: 0 0 0 2px var(--color-primary); }
  .cart-item-controls .qty { min-width: 28px; text-align: center; font-weight: 600; font-size: 0.95rem; padding: 0 0.25rem; }
  .cart-item-remove-link { display: inline-flex; align-items: center; min-height: 36px; padding: 0.4rem 0.85rem; margin-top: 0.6rem; margin-left: 0; color: var(--color-text); background: transparent; border: 1px solid rgba(31,41,55,.18); border-radius: 999px; text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: color 0.15s, border-color 0.15s, background 0.15s; }
  .cart-item-remove-link:hover, .cart-item-remove-link:focus-visible { color: var(--color-primary); border-color: var(--color-primary); outline: none; }
  @media (max-width: 767px) {
    .cart-item-controls .cart-qty-btn { min-width: 44px; min-height: 44px; width: 44px; height: 44px; }
    .cart-item-remove-link { min-height: 44px; padding: 0.6rem 1rem; }
  }
</style>

{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
