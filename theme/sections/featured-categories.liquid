<section class="section" data-testid="featured-categories">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Shop by Category</span>
      <h2>{{ section.settings.heading | default: 'Find what you <em>love</em>' }}</h2>
      <p>{{ section.settings.subheading | default: "From clever kitchen tools to cozy home finds, curated the way we'd shop for ourselves." }}</p>
    </div>

    <div class="categories-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '/collections/all' }}" class="category-card bg-{{ forloop.index | modulo: 4 | plus: 1 }}" data-testid="category-{{ block.settings.title | handleize }}">
          <div class="icon">{{ block.settings.emoji | default: '🐾' }}</div>
          <h3>{{ block.settings.title }}</h3>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Categories",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find what you <em>love</em>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "From clever kitchen tools to cozy home finds, curated the way we'd shop for ourselves." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Home & Living" },
        { "type": "text", "id": "emoji", "label": "Emoji icon", "default": "🏡" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Home & Living", "emoji": "🏡" } },
        { "type": "category", "settings": { "title": "Kitchen", "emoji": "🍳" } },
        { "type": "category", "settings": { "title": "Tech & Gadgets", "emoji": "💡" } },
        { "type": "category", "settings": { "title": "On the Go", "emoji": "🎒" } }
      ]
    }
  ]
}
{% endschema %}
