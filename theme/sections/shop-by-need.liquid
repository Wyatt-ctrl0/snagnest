{%- if section.blocks.size > 0 -%}
<section class="section shop-by-need" data-testid="shop-by-need" style="background: var(--color-bg);">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">{{ section.settings.eyebrow | default: 'Browse by category' }}</span>
      <h2>{{ section.settings.heading | default: 'Shop by <em>category</em>' }}</h2>
      <p>{{ section.settings.subheading | default: 'Trending finds across every corner of your life. Start wherever you need it most.' }}</p>
    </div>

    <div class="need-grid">
      {%- for block in section.blocks -%}
        {%- assign tile_collection = collections[block.settings.collection] -%}
        {%- assign tile_url = block.settings.link | default: tile_collection.url | default: '/collections/all' -%}
        <a class="need-tile" href="{{ tile_url }}" {{ block.shopify_attributes }} data-testid="need-tile-{{ forloop.index }}" style="--tile-bg: {{ block.settings.bg_color | default: '#FBF4E7' }};">
          {%- if block.settings.image != blank -%}
            <span class="need-tile-media" aria-hidden="true" style="background-image: url('{{ block.settings.image | image_url: width: 600 }}');"></span>
          {%- else -%}
            <span class="need-tile-icon" aria-hidden="true">{%- render 'icon-glyph', glyph: block.settings.icon | default: 'bag' -%}</span>
          {%- endif -%}
          <span class="need-tile-body">
            <span class="need-tile-title">{{ block.settings.title | default: 'Shop' }}</span>
            {%- if block.settings.blurb != blank -%}
              <span class="need-tile-blurb">{{ block.settings.blurb }}</span>
            {%- endif -%}
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}

{% stylesheet %}
.shop-by-need .need-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1rem; margin-top: 1.75rem; }
.shop-by-need .need-tile { display: flex; align-items: center; gap: 1rem; padding: 1.1rem 1.25rem; border-radius: 16px; background: var(--tile-bg); border: 1px solid rgba(31,41,55,0.06); text-decoration: none; color: var(--color-text); transition: transform .18s ease, box-shadow .18s ease; min-height: 88px; }
.shop-by-need .need-tile:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(31,41,55,0.08); }
.shop-by-need .need-tile-icon { font-size: 2rem; line-height: 1; flex-shrink: 0; width: 2.5rem; display: flex; align-items: center; justify-content: center; }
.shop-by-need .need-tile-icon .ms-icon { width: 30px; height: 30px; color: #2B2622; display: block; }
.shop-by-need .need-tile-media { width: 56px; height: 56px; border-radius: 12px; background-size: cover; background-position: center; flex-shrink: 0; }
.shop-by-need .need-tile-body { display: flex; flex-direction: column; gap: .15rem; flex: 1; min-width: 0; }
.shop-by-need .need-tile-title { font-family: var(--font-heading); font-weight: 800; font-size: 1.05rem; line-height: 1.15; }
.shop-by-need .need-tile-blurb { font-size: .8rem; color: rgba(31,41,55,0.62); line-height: 1.3; }
.shop-by-need .need-tile:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
{% endstylesheet %}

{% schema %}
{
  "name": "Shop by Need",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Browse by category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by <em>category</em>" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Trending finds across every corner of your life. Start wherever you need it most." }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Need Tile",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Home & Living" },
        { "type": "text", "id": "blurb", "label": "Short blurb", "default": "Small upgrades, big difference at home." },
        { "type": "text", "id": "icon", "label": "Icon key (snowflake, bed, bag, heart, shield, truck, returns) or emoji", "default": "bag" },
        { "type": "collection", "id": "collection", "label": "Collection (sets the link)" },
        { "type": "url", "id": "link", "label": "Custom link (overrides collection)" },
        { "type": "image_picker", "id": "image", "label": "Image (optional, replaces icon)" },
        { "type": "color", "id": "bg_color", "label": "Tile background", "default": "#FBF4E7" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{
    "name": "Shop by Need",
    "blocks": [
      { "type": "tile", "settings": { "title": "Home & Living", "blurb": "Small upgrades that make a big difference.", "icon": "heart", "bg_color": "#FCE8DA" } },
      { "type": "tile", "settings": { "title": "Stay Cozy", "blurb": "Warm layers and soft things for slower days.", "icon": "snowflake", "bg_color": "#D2EFEF" } },
      { "type": "tile", "settings": { "title": "Kitchen", "blurb": "Tools that make cooking and hosting easier.", "icon": "bag", "bg_color": "#E8F0D4" } },
      { "type": "tile", "settings": { "title": "On the Go", "blurb": "Carry-friendly finds for every kind of trip.", "icon": "truck", "bg_color": "#FFE4D4" } },
      { "type": "tile", "settings": { "title": "Tech & Gadgets", "blurb": "Clever devices worth talking about.", "icon": "shield", "bg_color": "#FBF4E7" } },
      { "type": "tile", "settings": { "title": "Gifting", "blurb": "Finds that feel personal, priced for real life.", "icon": "bed", "bg_color": "#EFE6F2" } }
    ]
  }]
}
{% endschema %}
