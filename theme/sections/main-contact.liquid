<section class="section" data-testid="contact-page">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">We'd Love to Hear From You</span>
      <h1>Get in <em>touch</em></h1>
      <p>Questions, feedback, or just want to tell us about a product you love? We read every email.</p>
    </div>

    <div class="contact-grid">
      <div>
        <h2 style="margin-bottom:1.5rem;">Reach out</h2>
        <div class="contact-info-card">
          <div class="icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <h3>Email us</h3>
            <p style="margin:0;"><a class="contact-info-primary" href="mailto:{{ settings.email | default: 'support@snagnest.com' }}" data-testid="contact-email">{{ settings.email | default: 'support@snagnest.com' }}</a></p>
            <p class="contact-info-helper">We reply within 24 hours.</p>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h3>Call us</h3>
            <p style="margin:0;"><a class="contact-info-primary" href="tel:+15706711534" data-testid="contact-phone">{{ settings.phone | default: '(555) 010-2025' }}</a></p>
            <p class="contact-info-helper">Mon–Fri, 9am–5pm ET.</p>
          </div>
        </div>

        <div class="contact-info-card">
          <div class="icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
          </div>
          <div>
            <h3>Response time</h3>
            <p style="margin:0;"><span class="contact-info-primary">Within 24 hours</span></p>
            <p class="contact-info-helper">Mon–Fri.</p>
          </div>
        </div>
      </div>

      <div>
        <h2 style="margin-bottom:1.5rem;">Send a message</h2>
        {%- form 'contact', class: 'contact-form', id: 'ContactForm' -%}
          <div aria-live="polite" aria-atomic="true">
            {%- if form.posted_successfully? -%}
              <div class="form-success" data-testid="contact-success" role="status">✓ Thanks! We'll get back to you soon.</div>
            {%- endif -%}
            {%- if form.errors -%}
              <div class="form-error" role="alert">{{ form.errors | default_errors }}</div>
            {%- endif -%}
          </div>

          <div>
            <label for="contact-name">Name</label>
            <input id="contact-name" type="text" name="contact[name]" required data-testid="contact-name" autocomplete="name">
          </div>
          <div>
            <label for="contact-email">Email</label>
            <input id="contact-email" type="email" name="contact[email]" required data-testid="contact-input-email" autocomplete="email">
          </div>
          <div>
            <label for="contact-subject">Subject</label>
            <input id="contact-subject" type="text" name="contact[subject]" data-testid="contact-subject">
          </div>
          <div>
            <label for="contact-body">Message</label>
            <textarea id="contact-body" name="contact[body]" required data-testid="contact-message"></textarea>
          </div>
          <button type="submit" class="btn btn-primary" data-testid="contact-submit">Send Message</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

<style>
  /* v18 final: every contact-info card uses .contact-info-primary +
     .contact-info-helper so font, weight, and color match across cards 1, 2,
     and 3. Weight pinned to 700 so the bare span on card 3 matches the
     bold links on cards 1 + 2. */
  .contact-info-primary { font-family: var(--font-body); font-weight: 700; color: var(--color-text); text-decoration: none; }
  a.contact-info-primary { color: var(--color-text); }
  a.contact-info-primary:hover { color: var(--color-primary); text-decoration: underline; text-underline-offset: 2px; }
  .contact-info-helper { margin: 0.25rem 0 0; font-size: 0.85rem; color: rgba(31, 41, 55, 0.78); font-family: var(--font-body); }
</style>

{% schema %}
{ "name": "Contact", "settings": [] }
{% endschema %}
